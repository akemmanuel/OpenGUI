{
	"name": "opengui",
	"version": "0.2.8",
	"private": false,
	"description": "OpenGUI - A graphical interface for OpenCode",
	"homepage": "https://github.com/akemmanuel/OpenGUI",
	"license": "MIT",
	"author": {
		"name": "Emmanuel",
		"email": "emmanuel@akemsoft.com"
	},
	"type": "module",
	"main": "main.cjs",
	"scripts": {
		"dev": "bun dev.ts",
		"dev:web": "bun --hot src/index.ts",
		"start": "NODE_ENV=production bun src/index.ts",
		"start:electron": "NODE_ENV=production bunx electron .",
		"build": "bun run build.ts",
		"dist": "bunx electron-builder --linux deb",
		"dist:mac": "bunx electron-builder --mac dmg",
		"dist:mac:arm64": "bunx electron-builder --mac dmg --arm64",
		"dist:win": "bunx electron-builder --win nsis",
		"dist:win:portable": "bunx electron-builder --win portable",
		"typecheck": "oxlint --type-aware --type-check",
		"lint": "oxlint --type-aware",
		"lint:check": "oxlint --type-aware",
		"lint:fix": "oxlint --type-aware --fix"
	},
	"dependencies": {
		"@opencode-ai/sdk": "^1.3.0",
		"@tanstack/react-virtual": "^3.13.23",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"katex": "^0.16.40",
		"lucide-react": "^0.577.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"rehype-katex": "^7.0.1",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"shiki": "^3.23.0",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"bun-plugin-tailwind": "^0.1.2",
		"electron": "^40.8.3",
		"oxlint": "^1.57.0",
		"oxlint-tsgolint": "^0.17.3",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0"
	},
	"build": {
		"appId": "com.opengui.app",
		"productName": "OpenGUI",
		"compression": "maximum",
		"asar": true,
		"linux": {
			"target": "deb",
			"icon": "assets/icon.png",
			"category": "Development"
		},
		"mac": {
			"target": "dmg",
			"icon": "assets/icon.icns",
			"category": "public.app-category.developer-tools",
			"hardenedRuntime": true,
			"gatekeeperAssess": false,
			"identity": null
		},
		"dmg": {
			"icon": "assets/icon.icns"
		},
		"win": {
			"target": "nsis",
			"icon": "assets/icon.png"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "OpenGUI"
		},
		"files": [
			"dist/**/*",
			"!dist/**/*.map",
			"main.cjs",
			"preload.cjs",
			"opencode-bridge.mjs",
			"package.json",
			"!node_modules",
			"node_modules/@opencode-ai/sdk/dist/**/*.js",
			"node_modules/@opencode-ai/sdk/package.json"
		],
		"directories": {
			"output": "release"
		},
		"nodeGypRebuild": false,
		"npmRebuild": false
	}
}
