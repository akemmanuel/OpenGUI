{
  "name": "opengui",
  "version": "0.5.26",
  "private": false,
  "description": "OpenGUI - Desktop and web command center for coding agents",
  "homepage": "https://github.com/akemmanuel/OpenGUI",
  "license": "MIT",
  "author": {
    "name": "Emmanuel",
    "email": "emmanuel@akemsoft.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/akemmanuel/OpenGUI.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "node ./scripts/ensure-electron.mjs",
    "prepare": "vp config",
    "dev": "node --experimental-strip-types scripts/dev-desktop.ts",
    "dev:web": "vp dev",
    "build": "vp build",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "fmt": "vp fmt",
    "fmt:fix": "vp fmt --fix",
    "test": "vp test",
    "start": "NODE_ENV=production vp exec electron . --no-sandbox",
    "start:web": "HOST=0.0.0.0 NODE_ENV=production node --experimental-strip-types server/web-server.ts",
    "dist:linux": "vp build && electron-builder --linux deb AppImage",
    "dist:linux:appimage": "vp build && electron-builder --linux AppImage",
    "dist:mac": "vp build && electron-builder --mac dmg",
    "dist:mac:arm64": "vp build && electron-builder --mac dmg --arm64",
    "dist:win": "vp build && electron-builder --win nsis",
    "dist:win:portable": "vp build && electron-builder --win portable",
    "mobile:sync": "vp build && cap sync android",
    "mobile:open": "cap open android",
    "mobile:build:debug": "vp build && cap sync android && bash -lc 'cd android && ./gradlew assembleDebug'",
    "mobile:build:release": "vp build && cap sync android && bash -lc 'cd android && ./gradlew assembleRelease'",
    "prototype:claude-sdk": "node scripts/prototype-claude-sdk-terminal.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@capacitor/core": "^8.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@earendil-works/pi-agent-core": "0.78.1",
    "@earendil-works/pi-ai": "0.78.1",
    "@earendil-works/pi-coding-agent": "0.78.1",
    "@earendil-works/pi-tui": "0.78.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@hono/node-server": "^2.0.4",
    "@openai/codex-sdk": "^0.137.0",
    "@opencode-ai/sdk": "^1.16.2",
    "@tanstack/react-virtual": "^3.14.2",
    "@wooorm/starry-night": "^3.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.21.3",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "hono": "^4.12.23",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vscode-oniguruma": "^2.0.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@voidzero-dev/vite-plus-test": "^0.1.24",
    "electron": "42.3.3",
    "electron-builder": "^26.15.1",
    "esbuild": "^0.28.0",
    "js-yaml": "^4.2.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "sax": "1.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.16",
    "vite-plus": "^0.1.24",
    "which": "^7.0.0"
  },
  "packageManager": "pnpm@11.5.2",
  "build": {
    "appId": "com.opengui.app",
    "productName": "OpenGUI",
    "compression": "maximum",
    "asar": {
      "smartUnpack": true
    },
    "asarUnpack": [
      "dist-electron/backend.js",
      "dist-electron/backend.js.map",
      "dist-electron/package.json",
      "dist-electron/pi-daemon-server.js",
      "dist-electron/pi-daemon-server.js.map"
    ],
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "icon": "assets/icon.png",
      "category": "Development",
      "syncDesktopName": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}-mac.${ext}",
      "compression": "normal",
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "icon": "assets/icon.icns",
      "writeUpdateInfo": false
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "artifactName": "OpenGUI.Setup.${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenGUI"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "dist-electron/**/*",
      "package.json",
      "node_modules/@anthropic-ai/sdk/**/*",
      "node_modules/@openai/codex-sdk/**/*",
      "!node_modules/@openai/codex-sdk/node_modules/@openai/codex-*/**/*",
      "!node_modules/@openai/codex-sdk/node_modules/@openai/codex/**/*",
      "node_modules/@earendil-works/pi-coding-agent/**/*",
      "node_modules/@earendil-works/pi-agent-core/**/*",
      "node_modules/@earendil-works/pi-ai/**/*",
      "node_modules/@earendil-works/pi-tui/**/*",
      "node_modules/@silvia-odwyer/photon-node/**/*",
      "node_modules/typebox/**/*",
      "node_modules/chalk/**/*",
      "node_modules/cli-highlight/**/*",
      "node_modules/diff/**/*",
      "node_modules/extract-zip/**/*",
      "node_modules/file-type/**/*",
      "node_modules/glob/**/*",
      "node_modules/hosted-git-info/**/*",
      "node_modules/ignore/**/*",
      "node_modules/marked/**/*",
      "node_modules/minimatch/**/*",
      "node_modules/proper-lockfile/**/*",
      "node_modules/strip-ansi/**/*",
      "node_modules/undici/**/*",
      "node_modules/uuid/**/*",
      "node_modules/yaml/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/sax/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "akemmanuel",
        "repo": "OpenGUI"
      }
    ],
    "nodeGypRebuild": false,
    "npmRebuild": false
  },
  "desktopName": "OpenGUI"
}
