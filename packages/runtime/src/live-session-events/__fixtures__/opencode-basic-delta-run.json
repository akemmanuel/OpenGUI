{
  "description": "OpenCode-style text deltas append progressively like Pi snapshots",
  "harnessEvents": [
    {
      "type": "message.part.delta",
      "sessionID": "s1",
      "messageID": "m1",
      "partID": "p1",
      "field": "text",
      "delta": "O"
    },
    {
      "type": "message.part.delta",
      "sessionID": "s1",
      "messageID": "m1",
      "partID": "p1",
      "field": "text",
      "delta": "P"
    },
    {
      "type": "message.part.delta",
      "sessionID": "s1",
      "messageID": "m1",
      "partID": "p1",
      "field": "text",
      "delta": "EN"
    }
  ],
  "expectEventTypes": [
    "message.started",
    "part.started",
    "part.text.appended",
    "part.text.appended",
    "part.text.appended"
  ],
  "expectFinalText": "OPEN"
}
