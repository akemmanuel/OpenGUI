{
  "description": "Run idle after assistant text emits message.finished best-effort",
  "harnessEvents": [
    { "type": "session.status", "sessionID": "s1", "status": { "type": "running" } },
    {
      "type": "message.part.delta",
      "sessionID": "s1",
      "messageID": "m1",
      "partID": "p1",
      "field": "text",
      "delta": "ok"
    },
    { "type": "session.status", "sessionID": "s1", "status": { "type": "idle" } }
  ],
  "expectEventTypes": [
    "run.started",
    "message.started",
    "part.started",
    "part.text.appended",
    "run.finished",
    "message.finished"
  ],
  "expectFinalText": "ok"
}
