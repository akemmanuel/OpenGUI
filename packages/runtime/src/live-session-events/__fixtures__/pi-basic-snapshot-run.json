{
  "description": "Progressive Pi-style text part snapshots become append events",
  "harnessEvents": [
    {
      "type": "message.part.updated",
      "part": {
        "id": "p1",
        "sessionID": "s1",
        "messageID": "m1",
        "type": "text",
        "text": "OP",
        "tokens": {}
      }
    },
    {
      "type": "message.part.updated",
      "part": {
        "id": "p1",
        "sessionID": "s1",
        "messageID": "m1",
        "type": "text",
        "text": "OPENG",
        "tokens": {}
      }
    },
    {
      "type": "message.part.updated",
      "part": {
        "id": "p1",
        "sessionID": "s1",
        "messageID": "m1",
        "type": "text",
        "text": "OPENGUI",
        "tokens": {}
      }
    }
  ],
  "expectEventTypes": [
    "message.started",
    "part.started",
    "part.text.appended",
    "part.text.appended",
    "part.text.appended"
  ],
  "expectFinalText": "OPENGUI"
}
