{
  "description": "Repeated busy/idle session.status observations collapse to one run lifecycle pair",
  "harnessEvents": [
    { "type": "session.status", "sessionID": "s1", "status": { "type": "busy" } },
    { "type": "session.status", "sessionID": "s1", "status": { "type": "busy" } },
    { "type": "session.status", "sessionID": "s1", "status": { "type": "idle" } },
    { "type": "session.status", "sessionID": "s1", "status": { "type": "idle" } }
  ],
  "expectEventTypes": ["run.started", "run.finished"]
}
